# Copy to /etc/sspay-crm.env on the server (chmod 600) and edit values.
# deploy.sh creates this for you on first run if it's missing.

DJANGO_SECRET_KEY=replace-with-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.sspay.online
DJANGO_CORS_ORIGINS=https://portal.sspay.online
DJANGO_CSRF_TRUSTED_ORIGINS=https://portal.sspay.online,https://api.sspay.online
