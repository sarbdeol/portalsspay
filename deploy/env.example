# Copy to /etc/sspay-crm.env on the server (chmod 600) and edit values.
# deploy.sh creates this for you on first run if it's missing.

DJANGO_SECRET_KEY=replace-with-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.rdlink.online
DJANGO_CORS_ORIGINS=https://rdlink.online
DJANGO_CSRF_TRUSTED_ORIGINS=https://rdlink.online,https://api.rdlink.online
DJANGO_MEDIA_ROOT=/var/lib/sspay-crm/media
